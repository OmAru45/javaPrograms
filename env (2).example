const db = require('../config/db');
const { asyncHandler } = require('../middleware/errorHandler');

const STORE_SORT_COLUMNS = { name: 's.name', address: 's.address', rating: 'average_rating' };

// GET /api/stores?name=&address=&sortBy=&sortOrder=
// Lists stores for the logged-in normal user, including the overall
// average rating and that user's own submitted rating (if any).
const listStoresForUser = asyncHandler(async (req, res) => {
  const { name, address, sortBy = 'name', sortOrder = 'asc' } = req.query;

  const conditions = [];
  const params = [req.user.id];

  if (name) { params.push(`%${name}%`); conditions.push(`s.name ILIKE $${params.length}`); }
  if (address) { params.push(`%${address}%`); conditions.push(`s.address ILIKE $${params.length}`); }

  const whereClause = conditions.length ? `WHERE ${conditions.join(' AND ')}` : '';
  const orderColumn = STORE_SORT_COLUMNS[sortBy] || STORE_SORT_COLUMNS.name;
  const orderDirection = sortOrder === 'desc' ? 'DESC' : 'ASC';

  const result = await db.query(
    `SELECT s.id, s.name, s.address,
            ROUND(AVG(r.rating)::numeric, 2) AS average_rating,
            COUNT(r.id)::int AS rating_count,
            ur.rating AS my_rating
     FROM stores s
     LEFT JOIN ratings r ON r.store_id = s.id
     LEFT JOIN ratings ur ON ur.store_id = s.id AND ur.user_id = $1
     ${whereClause}
     GROUP BY s.id, ur.rating
     ORDER BY ${orderColumn} ${orderDirection}`,
    params
  );

  return res.json({ stores: result.rows });
});

// POST /api/stores/:id/ratings — create or update (upsert) the logged-in
// user's rating for one store. Body: { rating: 1-5 }.
const submitRating = asyncHandler(async (req, res) => {
  const storeId = req.params.id;
  const { rating } = req.body;

  const store = await db.query('SELECT id FROM stores WHERE id = $1', [storeId]);
  if (store.rows.length === 0) {
    return res.status(404).json({ message: 'Store not found' });
  }

  const result = await db.query(
    `INSERT INTO ratings (user_id, store_id, rating)
     VALUES ($1, $2, $3)
     ON CONFLICT (user_id, store_id)
     DO UPDATE SET rating = EXCLUDED.rating
     RETURNING id, store_id, rating, created_at, updated_at`,
    [req.user.id, storeId, rating]
  );

  return res.status(200).json({ rating: result.rows[0] });
});

module.exports = { listStoresForUser, submitRating };
